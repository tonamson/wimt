# Copy to .env and adjust as needed:
#   cp .env.example .env
#
# Docker Compose reads this file automatically for ${VAR} substitution.
# Local `npm run dev` can use the same vars (export or a frontend/.env.local).

# --- Host ports (bound to 127.0.0.1 only) ---
WIMT_PORT=4393
HEADROOM_PORT=8787

# --- Headroom image build (pip install headroom-ai[proxy] from PyPI) ---
# Force reinstall of latest package when building:
#   HEADROOM_CACHEBUST=$(date +%s) docker compose build headroom
# HEADROOM_CACHEBUST=0
# Pin a specific version (empty = always latest):
# HEADROOM_VERSION=

# --- Public URL shown in dashboard for CLI export (WIMT entry) ---
PROXY_PUBLIC_BASE_URL=http://127.0.0.1:4393

# --- Upstream AI providers ---
OPENAI_UPSTREAM_BASE_URL=https://api.openai.com
ANTHROPIC_UPSTREAM_BASE_URL=https://api.anthropic.com
# auto | openai | anthropic
DEFAULT_PROVIDER=auto

# --- SQLite (inside container; host path is ./frontend/data via volume) ---
# WIMT_DB_PATH is set in docker-compose for the container.
# For local dev outside Docker:
# WIMT_DB_PATH=/absolute/path/to/wimt.sqlite

# --- Log retention: delete request rows older than N days (default 14) ---
WIMT_RETENTION_DAYS=14

# --- Body logging (request/response snapshots in SQLite) ---
# 1 = store truncated bodies (secrets redacted), 0 = usage/metadata only
WIMT_LOG_BODIES=1
WIMT_LOG_BODY_MAX=8000

# --- Optional debug ---
# WIMT_DEBUG_USAGE=1
